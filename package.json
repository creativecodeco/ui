    "@types/node": "25.0.5",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "chromatic": "13.3.5",
    "classnames": "2.5.1",
    "cpx2": "8.0.0",
    "daisyui": "5.5.14",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-config-standard-react": "13.0.0",
    "eslint-config-standard-with-typescript": "43.0.1",
    "eslint-plugin-import": "2.32.0",
